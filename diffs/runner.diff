+def _baseline_stats_for(contract_id: str, dataset: str) -> dict[str, dict[str, Any]]:
+    b = _load_numeric_baseline()
+    contracts = b.get("contracts")
+    if not isinstance(contracts, dict):
+        return {}
+    c = contracts.get(contract_id)
+    if not isinstance(c, dict):
+        return {}
+    ds = c.get(dataset)
+    if not isinstance(ds, dict):
+        return {}
+    out: dict[str, dict[str, Any]] = {}
+    for k, v in ds.items():
+        if isinstance(k, str) and isinstance(v, dict):
+            out[k] = v
+    return out
+
