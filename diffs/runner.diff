+def _expected_from_rule(rule: dict[str, Any]) -> Any:
+    rtype = str(rule.get("type") or "")
+    if rtype in ("range", "range_inferred"):
+        return {"min": rule.get("min"), "max": rule.get("max")}
+    if rtype == "enum":
+        return {"values": rule.get("values")}
+    if rtype in ("uuid_v4", "regex"):
+        return {"pattern": rule.get("pattern")}
+    if rtype in ("not_null",):
+        return {"required": True}
+    if rtype in ("relationships",):
+        return {"to_dataset": rule.get("to_dataset"), "field": rule.get("field"), "ref_field": rule.get("ref_field")}
+    if "expected" in rule:
+        return {"expected": rule.get("expected")}
+    return {}
 
 
