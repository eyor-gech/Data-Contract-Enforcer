+def _latest_snapshot_id(contract_id: str) -> str | None:
+    d = os.path.join("schema_snapshots", contract_id)
+    if not os.path.isdir(d):
+        return None
+    snaps = sorted([f for f in os.listdir(d) if f.endswith(".yaml")])
+    return snaps[-1] if snaps else None
