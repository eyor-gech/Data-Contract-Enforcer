+def _contract_required_fields(contract: dict[str, Any]) -> list[str]:
+    schema = contract.get("schema")
+    if not (isinstance(schema, list) and schema and isinstance(schema[0], dict)):
+        return []
+    props = schema[0].get("properties")
+    if not isinstance(props, list):
+        return []
+    out: list[str] = []
+    for p in props:
+        if isinstance(p, dict) and p.get("required") is True and isinstance(p.get("name"), str):
+            out.append(p["name"])
+    return sorted(set(out))
