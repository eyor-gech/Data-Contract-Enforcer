+def _baseline_drift_checks(
+    dataset: str,
+    indexed_rows: list[tuple[int, dict[str, Any]]],
+    baseline: dict[str, dict[str, Any]],
+) -> list[Violation]:
+    """
+    Baseline drift is a dataset-level statistical check.
+    WARNING at 2σ (MEDIUM), FAIL at 3σ (HIGH).
+    """
+    if not baseline:
+        return []
+    sums: dict[str, float] = defaultdict(float)
+    counts: dict[str, int] = defaultdict(int)
+    for _, row in indexed_rows:
+        for field in baseline.keys():
+            v = safe_float(_get_path(row, field))
+            if v is None:
+                continue
+            sums[field] += float(v)
+            counts[field] += 1
+
+    vios: list[Violation] = []
+    for field in sorted(baseline.keys()):
+        b = baseline.get(field) or {}
+        mean0 = safe_float(b.get("mean"))
+        std0 = safe_float(b.get("stdev"))
+        if mean0 is None or std0 is None or std0 <= 1e-12:
+            continue
+        n = counts.get(field, 0)
+        if n <= 0:
+            continue
+        mean1 = sums[field] / n
+        z = abs((mean1 - mean0) / std0)
+        if z < 2.0:
+            continue
+        severity = "MEDIUM" if z < 3.0 else "HIGH"
+        msg = (
+            f"Baseline drift detected: z={z:.3f} (warn>=2, fail>=3); "
+            f"baseline_mean={mean0:.6f}, current_mean={mean1:.6f}, baseline_std={std0:.6f}"
+        )
+        vios.append(
+            Violation(
+                vtype="STATISTICAL",
+                field=field,
+                severity=severity,
+                count=1,
+                root_cause=dataset,
+                lineage_path=_blame_chain(dataset),
+                clause_id=f"baseline_drift:{field}",
+                message=msg,
+                samples=[{"baseline_mean": mean0, "current_mean": mean1, "baseline_std": std0, "z": z, "n": n}],
+            )
+        )
+    return vios
+
