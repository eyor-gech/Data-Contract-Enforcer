+def _load_numeric_baseline() -> dict[str, Any]:
+    path = os.path.join("schema_snapshots", "baselines.json")
+    if not os.path.exists(path):
+        return {}
+    try:
+        with open(path, "r", encoding="utf-8") as f:
+            obj = json.load(f)
+            return obj if isinstance(obj, dict) else {}
+    except Exception:
+        return {}
